{
  "name": "snap-html",
  "type": "module",
  "version": "0.0.0",
  "description": "API to capture screenshots of HTML/URLs using Puppeteer",
  "author": "Maximiliano Garcia Mortigliengo",
  "license": "ISC",
  "homepage": "https://github.com/MaxiGarcia13/snap-html#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxiGarcia13/snap-html.git"
  },
  "bugs": {
    "url": "https://github.com/MaxiGarcia13/snap-html/issues"
  },
  "keywords": [
    "puppeteer",
    "node-js",
    "screenshot",
    "html-to-image",
    "url-to-png",
    "rest-api"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "npx puppeteer browsers install chrome"
  },
  "dependencies": {
    "fastify": "^5.8.5",
    "puppeteer": "^24.43.1"
  },
  "devDependencies": {
    "@maxigarcia/eslint-config": "^1.5.0",
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3"
  }
}
